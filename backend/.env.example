# Copy this file to .env and fill in real values. Never commit .env.

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Off by default so registration/login work with zero email setup.
# Set to true once SMTP is configured if you want to require verified
# emails before login.
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Optional. If left blank, verification/reset emails are logged instead of
# sent — the app still fully works, you just read the link from the server
# log. A free Gmail app password or Brevo free tier both work fine here.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@clauseguard.local
SMTP_USE_TLS=true

# SQLite by default — no setup needed. Swap to Postgres later:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/clauseguard
DATABASE_URL=sqlite+aiosqlite:///./clauseguard.db

STORAGE_ROOT=./storage/uploads

# Set to "s3" for real persistent storage (recommended: Cloudflare R2, free
# tier, no egress fees). Leave as "local" for local dev / a quick demo
# deploy where losing uploaded files on restart is acceptable.
STORAGE_BACKEND=local
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# Free key: https://console.groq.com/keys (no credit card required)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

MAX_FILE_SIZE_MB=25
MAX_PAGES=200
MAX_CLAUSES_PER_DOCUMENT=60
MIN_EXTRACTED_WORDS=50
MAX_CONCURRENT_ANALYSES=5

FREE_PLAN_ANALYSES_LIMIT=3
STARTER_PLAN_ANALYSES_LIMIT=20
PRO_PLAN_ANALYSES_LIMIT=500

# Stripe TEST mode is free, no KYC needed to build/test with it.
# Get test keys at https://dashboard.stripe.com/test/apikeys
# Create two recurring Prices in test mode (Starter, Pro) and paste their IDs below.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
FRONTEND_URL=http://127.0.0.1:5173

OCR_ENABLED=true
OCR_CHAR_THRESHOLD_PER_PAGE=100
